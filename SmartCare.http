@baseUrl = http://localhost:5000
@token =

### ── AUTH ─────────────────────────────────────────────────────────────────

### Register – Patient (public)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "fullName": "Test Patient",
  "email": "newpatient@smartcare.com",
  "password": "Patient123!",
  "dateOfBirth": "1995-03-20",
  "gender": "Male",
  "contactNumber": "555-0199",
  "address": "456 Oak Ave"
}

###

### Login – Admin (seed user)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@smartcare.com",
  "password": "Admin123!"
}

###

### Login – Doctor (seed user)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "doctor@smartcare.com",
  "password": "Doctor123!"
}

###

### Login – Receptionist (seed user)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "reception@smartcare.com",
  "password": "Reception123!"
}

###

### Login – Patient (seed user)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "patient@smartcare.com",
  "password": "Patient123!"
}

###

### Register Staff – Doctor  (requires Admin token in @token)
POST {{baseUrl}}/api/auth/register/staff
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Dr. Sarah Lee",
  "email": "sarah.lee@smartcare.com",
  "password": "Doctor123!",
  "role": "Doctor",
  "specialization": "Neurology",
  "licenseNumber": "LIC-2024-002"
}

###

### Register Staff – Receptionist  (requires Admin token in @token)
POST {{baseUrl}}/api/auth/register/staff
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Bob Green",
  "email": "bob.green@smartcare.com",
  "password": "Reception123!",
  "role": "Receptionist",
  "employeeId": "EMP-002"
}

###

### Register Staff – Admin  (requires Admin token in @token)
POST {{baseUrl}}/api/auth/register/staff
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Super Admin",
  "email": "admin2@smartcare.com",
  "password": "Admin123!",
  "role": "Admin",
  "adminLevel": 2
}
